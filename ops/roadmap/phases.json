{
  "version": "1.1.0",
  "defaultMode": "done_and_in_progress",
  "phases": [
    {
      "id": "A",
      "title": "Foundation",
      "status": "done",
      "checks": [
        {
          "id": "foundation-files",
          "description": "Core foundation files exist",
          "command": "test -f package.json && test -f prisma/schema.prisma && test -f docker-compose.yml"
        },
        {
          "id": "foundation-typecheck",
          "description": "Type system is healthy",
          "command": "pnpm run typecheck"
        }
      ]
    },
    {
      "id": "B",
      "title": "Scanner MVP",
      "status": "done",
      "checks": [
        {
          "id": "scanner-unit-tests",
          "description": "Scanner-related unit tests pass",
          "command": "pnpm run test"
        },
        {
          "id": "scanner-ssrf-guard",
          "description": "SSRF guard implementation exists",
          "command": "rg -n \"SSRF_BLOCKED\" src/lib/normalizeAuditTargetUrl.ts"
        }
      ]
    },
    {
      "id": "C",
      "title": "Report UX + Summary JSON",
      "status": "done",
      "checks": [
        {
          "id": "summary-schema-v1",
          "description": "Summary schema v1 is present",
          "command": "rg -n \"asdev.audit.summary.v1\" src/lib/summary.ts src/lib/summary.types.ts"
        },
        {
          "id": "report-route-present",
          "description": "Public report route exists",
          "command": "test -f src/app/api/reports/[token]/route.ts"
        }
      ]
    },
    {
      "id": "D",
      "title": "Lead/Order Gating",
      "status": "done",
      "checks": [
        {
          "id": "unlock-route-present",
          "description": "Unlock endpoint exists",
          "command": "test -f src/app/api/reports/[token]/unlock/route.ts"
        },
        {
          "id": "orders-endpoint-present",
          "description": "Order endpoint exists",
          "command": "test -f src/app/api/orders/route.ts"
        }
      ]
    },
    {
      "id": "E",
      "title": "Security and Ops Hardening",
      "status": "done",
      "checks": [
        {
          "id": "rate-limit-create-run",
          "description": "Rate limit control exists on create run",
          "command": "rg -n \"consumeDistributedRateLimit|RATE_LIMITED\" src/app/api/audit/runs/route.ts src/lib/rateLimit.ts"
        },
        {
          "id": "observability-request-id",
          "description": "Request id instrumentation exists",
          "command": "rg -n \"requestId|x-request-id\" src/lib/observability.ts src/app/api"
        },
        {
          "id": "metrics-endpoint",
          "description": "Prometheus-style metrics endpoint exists",
          "command": "test -f src/app/api/metrics/route.ts && rg -n \"audit_api_requests_total\" src/lib/metrics.ts"
        },
        {
          "id": "quality-gate",
          "description": "Full quality gate passes",
          "command": "pnpm run check"
        }
      ]
    },
    {
      "id": "F",
      "title": "Monetization and Delivery",
      "status": "done",
      "checks": [
        {
          "id": "payment-callback-route",
          "description": "Payment callback route is implemented",
          "command": "test -f src/app/api/payments/callback/route.ts"
        },
        {
          "id": "provider-integration",
          "description": "Payment provider integration exists",
          "command": "rg -n \"ZARINPAL|createCheckout|verifyCheckout\" src/lib/payments.ts src/app/api/payments/callback/route.ts"
        },
        {
          "id": "pdf-delivery-route",
          "description": "Paid PDF endpoint exists",
          "command": "test -f src/app/api/pdf/[token]/route.ts"
        }
      ]
    },
    {
      "id": "G",
      "title": "SEO Scale",
      "status": "done",
      "checks": [
        {
          "id": "guides-pipeline",
          "description": "Programmatic guides and pillar pages exist",
          "command": "test -f src/app/guides/page.tsx && test -f src/app/guides/[slug]/page.tsx && test -f src/app/pillar/iran-readiness-audit/page.tsx"
        },
        {
          "id": "seo-indexability",
          "description": "Sitemap and robots routes exist",
          "command": "test -f src/app/sitemap.ts && test -f src/app/robots.ts"
        }
      ]
    }
  ]
}
