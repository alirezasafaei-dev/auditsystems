{
  "name": "asdev-audit-ir",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "worker:dev": "tsx src/worker/index.ts",
    "jobs:enqueue:sample": "tsx src/scripts/enqueue-sample.ts",
    "roadmap:run": "tsx src/scripts/roadmap-automation.ts --strict",
    "roadmap:dry": "tsx src/scripts/roadmap-automation.ts --dry-run",
    "roadmap:phase": "tsx src/scripts/roadmap-automation.ts --phase",
    "seo:audit": "tsx src/scripts/seo-audit-automation.ts --strict",
    "seo:audit:dry": "tsx src/scripts/seo-audit-automation.ts --dry-run",
    "docs:generate": "tsx src/scripts/docs-automation.ts",
    "docs:refresh": "pnpm run docs:generate && pnpm run roadmap:run",
    "network:baseline": "tsx src/scripts/asdev-network-baseline.ts",
    "payment:preflight": "tsx src/scripts/payment-preflight.ts",
    "payment:preflight:strict": "tsx src/scripts/payment-preflight.ts --strict",
    "payment:zarinpal:smoke": "tsx src/scripts/zarinpal-smoke.ts",
    "automation:run": "tsx src/scripts/automation-master.ts --strict",
    "lighthouse:local": "tsx src/scripts/lighthouse-local.ts",
    "deploy:check:hosting": "bash scripts/deploy/check-hosting-sync.sh --strict",
    "deploy:readiness": "bash scripts/deploy/run-readiness-suite.sh --strict"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "next": "^15.5.12",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.5.12",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
